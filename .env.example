# ============================================================
# IP SLA Monitor - Environment Configuration
# ============================================================
# Copy this file to .env and update with your credentials.
#   cp .env.example .env
# ============================================================

# --- Cisco DNA Center ---
DNAC_HOST=https://sandboxdnac.cisco.com
DNAC_USERNAME=devnetuser
DNAC_PASSWORD=Cisco123!
DNAC_VERIFY_SSL=False

# --- NetBox ---
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=your-netbox-api-token-here
NETBOX_VERIFY_SSL=True

# --- Monitoring Settings ---
POLL_INTERVAL=300
LATENCY_THRESHOLD_MS=100
JITTER_THRESHOLD_MS=30
PACKET_LOSS_THRESHOLD_PCT=1.0
OUTPUT_DIR=./output
